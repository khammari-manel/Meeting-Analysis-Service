RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_HOST=localhost # Wenn du RabbitMQ aus Docker aufrufst nimm RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
CLOUDAMQP_URL=amqps://znqruvjn:aE3ToYtFYdbBnP-0ixQIWChPb1m-RsUi@sparrow.rmq.cloudamqp.com/znqruvjn

# Jira Configuration (optional)
# To enable Jira task creation from meeting protocols:
# 1. Go to https://id.atlassian.com/manage-profile/security/api-tokens
# 2. Create an API token
# 3. Fill in the values below:
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-api-token-here
